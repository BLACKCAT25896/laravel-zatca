{
    "name": "blackcat25896/laravel-zatca",
    "description": "Laravel ZATCA E-Invoice Implementation",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "laravel/tinker": "^2.8",
        "ramsey/uuid": "^4.7",
        "chillerlan/php-qrcode": "^4.3",
        "intervention/image": "^3.0",
        "guzzlehttp/guzzle": "^7.2",
        "spatie/laravel-data": "^4.8"
    },
    "require-dev": {
        "fakerphp/faker": "^1.20",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.5",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0",
        "laravel/dusk": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\": "database/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin-laravel": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
